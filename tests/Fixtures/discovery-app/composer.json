{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel-psl/discovery-app",
    "description": "Fixture Laravel application used to smoke test package auto-discovery.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "entrepeneur4lyf/laravel-psl": "dev-main",
        "laravel/framework": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../..",
            "options": {
                "symlink": true
            }
        }
    ],
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
